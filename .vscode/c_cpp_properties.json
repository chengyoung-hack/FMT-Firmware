{
  "configurations": [
    {
      "name": "windows-gcc-x64",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "_DEBUG",
        "UNICODE",
        "_UNICODE",
        "USE_STDPERIPH_DRIVER",
        "STM32H753XX",
        "__VFP_FP__",
        "ARM_MATH_MATRIX_CHECK",
        "ARM_MATH_CM7",
        "__FPU_PRESENT=1",
        "__FPU_USED=1"
      ],
      "windowsSdkVersion": "10.0.14393.0",
      "compilerPath": "gcc",
      "cStandard": "${default}",
      "cppStandard": "${default}",
      "intelliSenseMode": "windows-gcc-x64"
    }
  ],
  "version": 4
}